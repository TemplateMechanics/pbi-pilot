{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visual/1.2.0/schema.json",
  "name": "sales_by_category",
  "position": {
    "x": 40,
    "y": 160,
    "z": 2000,
    "width": 560,
    "height": 380,
    "tabOrder": 1
  },
  "visual": {
    "visualType": "clusteredBarChart",
    "query": {
      "queryState": {
        "Category": {
          "projections": [
